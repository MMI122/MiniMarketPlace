# Auto detect text files and perform LF normalization
* text=auto

# Java sources
*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.md text eol=lf

# Maven wrapper
/mvnw text eol=lf
*.cmd text eol=crlf
*.bat text eol=crlf

# Docker
Dockerfile text eol=lf
docker-compose.yml text eol=lf
.dockerignore text eol=lf

# Shell scripts
*.sh text eol=lf
